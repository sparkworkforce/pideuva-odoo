#. -----------------------------------------------------------------------
#. Field labels — uva.store.config
#. -----------------------------------------------------------------------

msgid "Store Name"
msgstr "Nombre de la tienda"

msgid "POS Configuration"
msgstr "Configuración de POS"

msgid "Uva API Key"
msgstr "Clave API de Uva"

msgid "Webhook Secret"
msgstr "Secreto de Webhook"

msgid "Auto-Accept Timeout (seconds)"
msgstr "Tiempo límite de auto-aceptación (segundos)"

msgid "Demo Mode"
msgstr "Modo demostración"

msgid "When enabled, all Uva API calls return mock responses. Enabled by default — disable only after configuring real API credentials."
msgstr "Cuando está habilitado, todas las llamadas al API de Uva devuelven respuestas simuladas. Habilitado por defecto — desactive solo después de configurar credenciales reales."

msgid "Enable Polling Fallback"
msgstr "Habilitar sondeo de respaldo"

msgid "Polling Interval (seconds)"
msgstr "Intervalo de sondeo (segundos)"

msgid "Last Polled At"
msgstr "Último sondeo"

msgid "POS Session State"
msgstr "Estado de sesión POS"

msgid "Connection Health"
msgstr "Estado de conexión"

#. -----------------------------------------------------------------------
#. Validation errors — uva.store.config
#. -----------------------------------------------------------------------

msgid "Polling interval must be at least %(min)s seconds to avoid rate-limiting by the Uva API. Got: %(val)s seconds."
msgstr "El intervalo de sondeo debe ser al menos %(min)s segundos para evitar límites de tasa del API de Uva. Valor recibido: %(val)s segundos."

msgid "Auto-accept timeout cannot be negative. Use 0 for manual-only mode."
msgstr "El tiempo de auto-aceptación no puede ser negativo. Use 0 para modo solo manual."

msgid "No active Uva store configuration found for this POS session. Please configure a Uva store under Point of Sale > Configuration > Uva Stores."
msgstr "No se encontró configuración activa de tienda Uva para esta sesión POS. Configure una tienda Uva en Punto de Venta > Configuración > Tiendas Uva."

#. -----------------------------------------------------------------------
#. Chatter — uva.store.config health
#. -----------------------------------------------------------------------

msgid "⚠️ Connection health is <b>%(status)s</b>. Last polled: %(last)s."
msgstr "⚠️ El estado de conexión es <b>%(status)s</b>. Último sondeo: %(last)s."

msgid "never"
msgstr "nunca"

msgid "Uva connection %(status)s"
msgstr "Conexión Uva %(status)s"

msgid "Store '%(name)s' health is %(status)s. Check API connectivity."
msgstr "El estado de la tienda '%(name)s' es %(status)s. Verifique la conectividad del API."

