<odoo>

    <record id="view_res_config_settings_uva_fleet" model="ir.ui.view">
        <field name="name">res.config.settings.uva.fleet</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base_setup.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[hasclass('settings')]" position="inside">
                <div class="app_settings_block" data-string="Uva Fleet"
                     id="uva_fleet_settings" data-testid="uva-fleet-settings-block">
                    <h2>Uva Fleet</h2>
                    <div class="row mt16 o_settings_container">
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_left_pane">
                                <field name="uva_fleet_demo_mode"
                                       widget="boolean_toggle"
                                       data-testid="fleet-demo-mode-toggle"/>
                            </div>
                            <div class="o_setting_right_pane">
                                <label for="uva_fleet_demo_mode" string="Demo Mode"/>
                                <div class="text-muted">
                                    Return mock responses for all Uva Fleet API calls.
                                    No real credentials required.
                                </div>
                            </div>
                        </div>
                        <div class="col-12 col-lg-6 o_setting_box"
                             groups="base.group_system">
                            <div class="o_setting_right_pane">
                                <label for="uva_fleet_api_key" string="Fleet API Key"/>
                                <field name="uva_fleet_api_key"
                                       groups="base.group_system"
                                       password="True"
                                       data-testid="fleet-api-key"/>
                                <label for="uva_fleet_webhook_secret"
                                       string="Fleet Webhook Secret"/>
                                <field name="uva_fleet_webhook_secret"
                                       groups="base.group_system"
                                       password="True"
                                       data-testid="fleet-webhook-secret"/>
                            </div>
                        </div>
                    </div>
                </div>
            </xpath>
        </field>
    </record>

</odoo>
