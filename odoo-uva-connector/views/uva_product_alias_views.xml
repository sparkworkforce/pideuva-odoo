<odoo>

    <record id="view_uva_product_alias_list" model="ir.ui.view">
        <field name="name">uva.product.alias.list</field>
        <field name="model">uva.product.alias</field>
        <field name="arch" type="xml">
            <list string="Product Aliases">
                <field name="alias_name"/>
                <field name="canonical_name"/>
                <field name="product_id"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="view_uva_product_alias_form" model="ir.ui.view">
        <field name="name">uva.product.alias.form</field>
        <field name="model">uva.product.alias</field>
        <field name="arch" type="xml">
            <form string="Product Alias">
                <sheet>
                    <group>
                        <field name="alias_name"/>
                        <field name="canonical_name"/>
                        <field name="product_id"/>
                        <field name="active" widget="boolean_toggle"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_uva_product_alias_search" model="ir.ui.view">
        <field name="name">uva.product.alias.search</field>
        <field name="model">uva.product.alias</field>
        <field name="arch" type="xml">
            <search>
                <field name="alias_name"/>
                <field name="canonical_name"/>
            </search>
        </field>
    </record>

    <record id="action_uva_product_alias" model="ir.actions.act_window">
        <field name="name">Product Aliases</field>
        <field name="res_model">uva.product.alias</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_uva_product_alias"
              name="Product Aliases"
              parent="menu_uva_root"
              action="action_uva_product_alias"
              sequence="35"/>

</odoo>
