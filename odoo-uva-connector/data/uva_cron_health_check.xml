<odoo>
    <data noupdate="1">
        <record id="ir_cron_uva_health_check" model="ir.cron">
            <field name="name">Uva PR: Connection Health Check</field>
            <field name="model_id" ref="model_uva_store_config"/>
            <field name="state">code</field>
            <field name="code">model.action_notify_health_issues()</field>
            <field name="interval_number">5</field>
            <field name="interval_type">minutes</field>
            <field name="numbercall">-1</field>
            <field name="active">True</field>
            <field name="priority">15</field>
        </record>
    </data>
</odoo>
