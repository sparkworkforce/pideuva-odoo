<odoo>
    <data noupdate="1">
        <!-- D-09: fast cron (1-minute interval) + per-record throttle in poll_orders_if_due() -->
        <record id="ir_cron_uva_order_polling" model="ir.cron">
            <field name="name">Uva PR: Poll Incoming Orders</field>
            <field name="model_id" ref="model_uva_order_service"/>
            <field name="state">code</field>
            <field name="code">model.poll_all_stores()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">minutes</field>
            <field name="numbercall">-1</field>
            <field name="active">True</field>
            <field name="priority">10</field>
        </record>
    </data>
</odoo>
