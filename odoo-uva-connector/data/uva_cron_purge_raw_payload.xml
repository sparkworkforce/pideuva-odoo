<!--
    GDPR/PR Privacy Compliance: raw_payload on uva.order.log contains PII
    (customer name, address, phone). Purge records older than 30 days.
    Also purges retry queue payloads (pickup/destination addresses).
-->
<odoo>
    <data noupdate="1">
        <record id="ir_cron_uva_purge_raw_payload" model="ir.cron">
            <field name="name">Uva PR: Purge Raw Payload (30-day PII cleanup)</field>
            <field name="model_id" ref="model_uva_order_log"/>
            <field name="state">code</field>
            <field name="code">model.purge_raw_payloads()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="nextcall" eval="(DateTime.now() + timedelta(days=1)).strftime('%Y-%m-%d 02:00:00')"/>
            <field name="active">True</field>
            <field name="priority">20</field>
        </record>
        <record id="ir_cron_uva_purge_retry_payload" model="ir.cron">
            <field name="name">Uva PR: Purge Retry Queue Payloads (30-day PII cleanup)</field>
            <field name="model_id" ref="model_uva_api_retry_queue"/>
            <field name="state">code</field>
            <field name="code">model.purge_done_payloads()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="nextcall" eval="(DateTime.now() + timedelta(days=1)).strftime('%Y-%m-%d 02:30:00')"/>
            <field name="active">True</field>
            <field name="priority">20</field>
        </record>
    </data>
</odoo>
